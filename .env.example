# =============================================================================
# Senior Scout 360 - Variáveis de Ambiente
# =============================================================================
# 
# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# O arquivo .env.local é ignorado pelo Git para proteger suas chaves.
#
# =============================================================================

# Google Gemini API Key
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# =============================================================================
# Backend URLs (Google Apps Script)
# =============================================================================
# Essas URLs já estão configuradas em services/apiConfig.ts
# Altere apenas se você tiver seu próprio backend

# BACKEND_URL=https://script.google.com/macros/s/SUA_URL_AQUI/exec
# LOOKUP_URL=https://script.google.com/macros/s/SUA_URL_AQUI/exec
